#include "app.h"
#include "stdbool.h"

extern void SystemClock_Config(void);


// Definition of system states
typedef enum {
	STATE_IDLE,		// OFF
	STATE_RUN		// ON
} SystemState_t;


typedef enum {
    BUTTON_NONE,   // Nic się nie stało
	BUTTON_SHORT,  // Krótkie kliknięcie
	BUTTON_LONG    // Długie przytrzymanie
} ButtonEvent_t;


static const uint32_t BUTTON_LONG_PRESS_TIME_MS = 2000;
static const uint32_t RELAY_INTERVAL_SHORT_MS = 1000;
static const uint32_t RELAY_INTERVAL_LONG_MS = 10000;

static volatile bool buttonPressedFlag = false;
// Setting the state when power is connected
static SystemState_t currentState = STATE_IDLE;


static void HandleIdleState(void);
static void HandleRunState(void);
static ButtonEvent_t CheckButtonEvent(void);
static int ManageRelayInterval(ButtonEvent_t buttonEvent);



/* Public functions */

// Application I/O initial state setup
void App_Init(void)
{
    HAL_GPIO_WritePin(LED_GPIO_Port, LED_Pin, GPIO_PIN_SET); 	 // LED OFF
    HAL_GPIO_WritePin(RELAY_GPIO_Port, RELAY_Pin, GPIO_PIN_SET); // RELAY OFF
}

// Application main loop
void App_Loop(void)
{
	// State selection: IDLE / RUN
	switch (currentState)
	{
		case STATE_IDLE:
			HandleIdleState();
			break;

		case STATE_RUN:
			HandleRunState();
			break;
	}
}


/* File local (static) function */

// Handles IDLE state
static void HandleIdleState(void)
{
	buttonPressedFlag = false;

	HAL_GPIO_WritePin(LED_GPIO_Port, LED_Pin, GPIO_PIN_SET); 	 // LED OFF
	HAL_GPIO_WritePin(RELAY_GPIO_Port, RELAY_Pin, GPIO_PIN_SET); // RELAY OFF

	// Sleep procedure
	HAL_SuspendTick(); // Disable SysTick interrupt
	HAL_PWR_EnterSTOPMode(PWR_MAINREGULATOR_ON, PWR_STOPENTRY_WFI); // Enter STOP mode (wait for interrupt)

	// Awakening procedure
	SystemClock_Config(); // Restore the previous high speed clock configuration
	HAL_ResumeTick(); 	  // Enable SysTick interrupt

	// Enter RUN state
	buttonPressedFlag = false;
	currentState = STATE_RUN;
}

// Handles RUN state
static void HandleRunState(void)
{
	ButtonEvent_t currentButtonEvent = CheckButtonEvent();
	uint32_t currentRelayInterval = ManageRelayInterval(currentButtonEvent);
	static uint32_t lastRelayTime = 0;

	//Operation logic
	if (HAL_GetTick() - lastRelayTime >= currentRelayInterval)
	{
		HAL_GPIO_TogglePin(RELAY_GPIO_Port, RELAY_Pin);
		HAL_GPIO_WritePin(LED_GPIO_Port, LED_Pin, !HAL_GPIO_ReadPin(RELAY_GPIO_Port, RELAY_Pin));
		lastRelayTime = HAL_GetTick();
	}


	// Enter IDLE state
	if (currentButtonEvent == BUTTON_SHORT)
		{
			buttonPressedFlag = false;
	     	currentState = STATE_IDLE;
	     	HAL_Delay(500);
	    }
}


static ButtonEvent_t CheckButtonEvent(void)
{
	if (!buttonPressedFlag)
	{
		return BUTTON_NONE;
	}


	uint32_t lastButtonPressTime = HAL_GetTick();
	bool isLongPress = false;

	while (HAL_GPIO_ReadPin(BUTTON_GPIO_Port, BUTTON_Pin) == false)
	{
		if (HAL_GetTick() - lastButtonPressTime >= BUTTON_LONG_PRESS_TIME_MS)
		{
			isLongPress = true;
			break;
		}
	}

	buttonPressedFlag = false;

	if (isLongPress)
	{
		return BUTTON_LONG;
	}
	else
	{
		return BUTTON_SHORT;
	}
}

static int ManageRelayInterval(ButtonEvent_t buttonEvent)
{
	static int currentInterval = RELAY_INTERVAL_SHORT_MS;

	if (buttonEvent == BUTTON_LONG)
	{
		if (currentInterval == RELAY_INTERVAL_SHORT_MS)
		{
			currentInterval = RELAY_INTERVAL_LONG_MS;
		}
		else
		{
			currentInterval = RELAY_INTERVAL_SHORT_MS;
		}

		for(int i=0; i<6; i++)
		{
			HAL_GPIO_TogglePin(LED_GPIO_Port, LED_Pin);
			HAL_Delay(50);
		}
	}
	return currentInterval;
}







// Interrupt service function
void HAL_GPIO_EXTI_Callback(uint16_t GPIO_Pin)
{

	// Button press interrupt
    if (GPIO_Pin == BUTTON_Pin)
    {
    	buttonPressedFlag = true;
    }
}

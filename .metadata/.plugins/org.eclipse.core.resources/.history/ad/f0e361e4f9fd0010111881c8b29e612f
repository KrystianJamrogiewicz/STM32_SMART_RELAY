#include "app.h"
#include "stdbool.h"

extern void SystemClock_Config(void);


// Definition of system states
typedef enum {
	STATE_IDLE,		// OFF
	STATE_RUN		// ON
} SystemState_t;

// Setting the state when power is connected
static SystemState_t currentState = STATE_IDLE;

static volatile bool buttonPressedFlag = false;


static void HandleIdleState(void);
static void HandleRunState(void);


/* Public functions */

// Application I/O initial state setup
void App_Init(void)
{
    HAL_GPIO_WritePin(LED_GPIO_Port, LED_Pin, GPIO_PIN_SET); 	 // LED OFF
    HAL_GPIO_WritePin(RELAY_GPIO_Port, RELAY_Pin, GPIO_PIN_SET); // RELAY OFF
}

// Application main loop
void App_Loop(void)
{
	// State selection: IDLE / RUN
	switch (currentState)
	{
		case STATE_IDLE:
			HandleIdleState();
			break;

		case STATE_RUN:
			HandleRunState();
			break;
	}
}


/* File local (static) function */

// Handles IDLE state
static void HandleIdleState(void)
{
	buttonPressedFlag = false;

	HAL_GPIO_WritePin(LED_GPIO_Port, LED_Pin, GPIO_PIN_SET); 	 // LED OFF
	HAL_GPIO_WritePin(RELAY_GPIO_Port, RELAY_Pin, GPIO_PIN_SET); // RELAY OFF

	// Sleep procedure
	HAL_SuspendTick(); // Disable SysTick interrupt
	HAL_PWR_EnterSTOPMode(PWR_MAINREGULATOR_ON, PWR_STOPENTRY_WFI); // Enter STOP mode (wait for interrupt)

	// Awakening procedure
	SystemClock_Config(); // Restore the previous high speed clock configuration
	HAL_ResumeTick(); 	  // Enable SysTick interrupt

	// Enter RUN state
	buttonPressedFlag = false;
	currentState = STATE_RUN;
}

// Handles RUN state
static void HandleRunState(void)
{
	//Operation logic
	HAL_GPIO_TogglePin(RELAY_GPIO_Port, RELAY_Pin);
	// HAL_GPIO_WritePin(LED_GPIO_Port, LED_Pin, !HAL_GPIO_ReadPin(RELAY_GPIO_Port, RELAY_Pin));
	HAL_Delay(200);


	// Enter IDLE state
	if (buttonPressedFlag == true)
		{
			buttonPressedFlag = false;
	     	currentState = STATE_IDLE;
	     	HAL_Delay(500);
	    }
}


// Interrupt service function
void HAL_GPIO_EXTI_Callback(uint16_t GPIO_Pin)
{

	// Button press interrupt
    if (GPIO_Pin == BUTTON_Pin)
    {
    	buttonPressedFlag = true;
    }
}
